# Django
DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Option 1 (recommended): full URL from Aiven console
# Example: postgresql://avnadmin:password@host:15432/defaultdb?sslmode=require
DATABASE_URL=

# Option 2: separate Aiven values
DB_ENGINE=django.db.backends.postgresql
AIVEN_DB_HOST=
AIVEN_DB_PORT=15432
AIVEN_DB_NAME=defaultdb
AIVEN_DB_USER=avnadmin
AIVEN_DB_PASSWORD=
AIVEN_SSLMODE=require
